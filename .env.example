# Copy this file to .env and fill in your values.
# The .env file is excluded from version control — never commit it.

# Full Ajera API endpoint URL including the encoded ?id= parameter.
# Found in Ajera under: Utility → Setup → Integrations → API Settings
AJERA_API_URL=https://ajera.com/VXXXXXX/AjeraAPI.ashx?id=XXXXXXXX

# API service account credentials.
# This must be a dedicated API user created in Ajera — NOT a regular employee login.
# Create under: Utility → Setup → Integrations → API Settings → API Users
# Grant only the read permissions your use case requires.
AJERA_USERNAME=your_api_username
AJERA_PASSWORD=your_api_password
